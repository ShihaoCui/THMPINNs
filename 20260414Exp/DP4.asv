clear all;
clc;
close all;

load('DATASUB.mat')

% 插值到每10天的时刻

t_sub = t_sub-t_sub(:,1);

% 作图
figure
hold on

plot(t_sub, Data_sub(:,1), '-')
plot(t_sub, Data_sub(:,2), '-')
plot(t_sub, Data_sub(:,3), '-')
plot(t_sub, Data_sub(:,4), '-')
plot(t_sub, Data_sub(:,5), '-')


legend("4m","5m","6m","7m","8m")
xlabel('Time (year)')
ylabel('Temperature C')


figure
plot([4,5,6,7,8],Data_sub(1,:))
sca
